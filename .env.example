# Gemini AI API Keys (Used in Client)
# For Vercel, prefix with VITE_. Use commas for multiple keys.
VITE_GEMINI_API_KEY=""
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Firebase Configuration (Required for Vercel/Production Backend)
FIREBASE_API_KEY="your-web-api-key"
FIREBASE_AUTH_DOMAIN="your-project-id.firebaseapp.com"
FIREBASE_PROJECT_ID="your-project-id"
FIREBASE_FIRESTORE_DATABASE_ID="(default)"
FIREBASE_CLIENT_EMAIL="firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com"
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# Or provide the full JSON object:
FIREBASE_SERVICE_ACCOUNT='{"project_id": "...", "private_key": "...", ...}'
